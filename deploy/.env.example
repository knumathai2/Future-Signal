# Optional. Leave empty to serve the repository's timestamped sample dataset.
# Applying migrations or collecting data into a production database requires
# explicit approval under AGENTS.md.
DATABASE_URL=

# Optional provider credentials for approved on-demand production workers.
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini

# Optional pool tuning for small hosted PostgreSQL plans.
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=1
DB_POOL_TIMEOUT_SECONDS=10

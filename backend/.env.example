# Copy to .env and fill in real values locally. Never commit .env.
ENV=local
DATABASE_URL=postgresql+psycopg://user:password@host:5432/outlook_signals
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# TASK-015: AI report generation (OpenAI, per human-approved ADR). Leave blank
# to keep the LLM path disabled - batch report generation then has nothing to
# call and every market falls through to status=failed, previous report stays
# live. Never commit a real key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# TASK-058~065 verified-context program. OpenRouter server-tool research is
# disabled unless a real key is supplied to an explicitly invoked batch/CLI.
# Hard maxima are clamped in config to 6 searches and 30 total results.
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Outlook Signals
CONTEXT_RESEARCH_MODEL=openai/gpt-4o-mini
# Required by TASK-059 live verification and must use a different provider
# family from CONTEXT_RESEARCH_MODEL (for example, not another openai/* model).
CONTEXT_VERIFIER_MODEL=
CONTEXT_SEARCH_ENGINE=auto
CONTEXT_MAX_SEARCH_QUERIES=6
CONTEXT_MAX_SEARCH_RESULTS=30
CONTEXT_MAX_RESULTS_PER_QUERY=5
CONTEXT_CHANGE_THRESHOLD=0.05
CONTEXT_STALENESS_HOURS=24
CONTEXT_BUDGET_USD=100
# Conservative pre-call reservation; a market is skipped when recorded spend
# plus this amount would exceed CONTEXT_BUDGET_USD.
CONTEXT_COST_RESERVATION_USD=2
